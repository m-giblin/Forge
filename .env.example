# ---------------------------------------------------------------------------
# Forge environment (copy to .env.local for dev). All config is env-driven.
# Dev server runs on :3100 (Travli owns :3000).
# ---------------------------------------------------------------------------

# Supabase — from your project's API settings (or `supabase start` for local).
# NEXT_PUBLIC_* values are exposed to the browser. The service-role key is NOT.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# SERVER ONLY. Bypasses RLS — never expose to the client. Used only on the
# machine/API-key path, where the repository injects tenant_id explicitly.
SUPABASE_SERVICE_ROLE_KEY=

# SERVER ONLY. Pepper for HMAC-SHA256 hashing of API keys (auth + issuance).
# Required in production — without it every /api/v1/* request returns 500.
# Generate once: openssl rand -hex 32. Must match the value used when keys were minted.
API_KEY_HASH_SECRET=

# Secret for signing the impersonation cookie. Optional — falls back to
# SUPABASE_SERVICE_ROLE_KEY if unset. Set this so rotating the Supabase key
# doesn't invalidate active support sessions. Generate: openssl rand -hex 32
IMPERSONATION_SECRET=

# AI provider (Grok by default, swappable behind the provider interface).
AI_PROVIDER=grok
GROK_API_KEY=

# Rate limiting (optional in dev; falls back to in-memory if unset).
RATE_LIMIT_REDIS_URL=

# Dogfood: a raw API key (mint on the API keys page) so the in-app "Report a bug"
# button can call /api/v1/issues. Files into the key's tenant. Optional.
#
# ROTATION PROCEDURE (L-6):
#   1. In Admin → API Keys for the Forge tenant, create a new key.
#   2. Update FORGE_SELF_API_KEY in Vercel (or hosting env) with the new key value.
#   3. Deploy / restart — the new key takes effect on next cold start.
#   4. Revoke the old key in Admin → API Keys (marks revoked_at in DB; stops it working immediately).
#   No database migration required. The key is only used server-side (never exposed to browsers).
FORGE_SELF_API_KEY=

# 32-byte hex key for AES-256-GCM encryption of tenant BYO LLM keys.
# Required only when the BYO LLM feature is active (Phase 3).
# Generate: openssl rand -hex 32
FORGE_AI_KEY_SECRET=
